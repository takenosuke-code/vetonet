# VetoNet Playground Environment Variables
# NOTE: Vite reads .env from the repo root (one directory up), not from playground/
# Copy this file to the repo root as .env

# Required for auth (sign-up/sign-in)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxx

# Optional: override API base URL (defaults to production)
# VITE_API_URL=https://api.veto-net.org/api
